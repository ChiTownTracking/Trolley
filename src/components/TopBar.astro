---
import { site, hasPhone, hasInstagram, hasFacebook } from '../data/site';
---
<div class="topbar">
  <div class="topbar__inner wrap wrap-wide">
    <div class="topbar__contact">
      {hasPhone ? (
        <a href={site.contact.phoneHref} class="topbar__link">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#D4AF6A" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
          {site.contact.phoneDisplay}
        </a>
      ) : (
        <span class="topbar__link">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#D4AF6A" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
          {site.contact.phoneDisplay}
        </span>
      )}
      <span class="topbar__divider"></span>
      <a href={`mailto:${site.contact.email}`} class="topbar__link topbar__link--email">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#D4AF6A" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="flex:none"><rect x="2" y="4" width="20" height="16" rx="2"></rect><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg>
        {site.contact.email}
      </a>
    </div>
    {(hasFacebook || hasInstagram) && (
      <nav class="topbar__social" aria-label="Social media">
        {hasFacebook && (
          <a
            href={site.social.facebook}
            class="topbar__socialLink"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Visit ChiTown Trolley on Facebook"
            title="Facebook"
          >
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false">
              <path d="M13.7 21v-8h2.7l.4-3.1h-3.1v-2c0-.9.3-1.5 1.6-1.5H17V3.6c-.3 0-1.3-.1-2.5-.1-2.5 0-4.2 1.5-4.2 4.3v2.1H7.5V13h2.8v8h3.4Z"></path>
            </svg>
          </a>
        )}
        {hasInstagram && (
          <a
            href={site.social.instagram}
            class="topbar__socialLink"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Visit ChiTown Trolley on Instagram"
            title="Instagram"
          >
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.7"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
              focusable="false"
            >
              <rect x="3" y="3" width="18" height="18" rx="5"></rect>
              <circle cx="12" cy="12" r="4"></circle>
              <circle cx="17.5" cy="6.5" r=".75" fill="currentColor" stroke="none"></circle>
            </svg>
          </a>
        )}
      </nav>
    )}
  </div>
</div>

<style>
  .topbar { background: var(--ink); }
  .topbar__inner {
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
  }
  .topbar__social {
    display: flex;
    align-items: center;
    gap: 16px;
    flex: none;
    margin-left: auto;
  }
  .topbar__socialLink {
    width: 32px;
    height: 32px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--gold);
    text-decoration: none;
    transition: color .2s ease, opacity .2s ease, transform .2s ease;
  }
  .topbar__socialLink svg {
    display: block;
    width: 17px;
    height: 17px;
  }
  .topbar__socialLink:hover {
    color: var(--gold-light);
    transform: translateY(-1px);
  }
  .topbar__socialLink:focus-visible {
    border-radius: 2px;
    outline: 2px solid var(--gold-light);
    outline-offset: 2px;
  }
  .topbar__contact {
    display: flex; align-items: center; gap: 28px;
    min-width: 0; overflow: hidden; justify-content: flex-start;
  }
  .topbar__link {
    font-size: 12.5px; letter-spacing: .06em; font-weight: 300;
    color: var(--gold-cream); text-decoration: none;
    display: flex; align-items: center; gap: 9px;
    white-space: nowrap; flex: none;
    transition: color .25s ease;
  }
  .topbar__link:hover { color: var(--gold-light); }
  .topbar__link--email { overflow: hidden; text-overflow: ellipsis; min-width: 0; }
  .topbar__divider { width: 1px; height: 14px; background: rgba(212, 175, 106, .35); }

  /* Keep the mobile strip focused: phone left, social links right. */
  @media (max-width: 768px) {
    .topbar__inner { gap: 12px; }
    .topbar__link--email,
    .topbar__divider { display: none; }
    .topbar__social {
      gap: 16px;
      margin-right: 0;
      margin-left: auto;
    }
    .topbar__socialLink {
      width: 44px;
      height: 40px;
    }
    .topbar__socialLink svg {
      width: 18px;
      height: 18px;
    }
    .topbar__contact {
      margin-right: auto;
      margin-left: 0;
      justify-content: flex-start;
    }
  }

  @media (max-width: 480px) {
    .topbar__inner { height: 44px; }
    .topbar__socialLink { height: 44px; }
  }
</style>
