---
import { navMain, navMore, site } from '../data/site';
import { withBase, withoutBase } from '../utils/paths';

// Normalize the current path (strip trailing slash) for active matching.
const path = withoutBase(Astro.url.pathname).replace(/\/+$/, '') || '/';
const isActive = (href: string) => (href === '/' ? path === '/' : path === href || path.startsWith(href + '/'));
const moreActive = navMore.some((n) => isActive(n.href));
---
<header class="hdr" data-site-header>
  <div class="hdr__inner wrap wrap-wide">
    <a href={withBase('/')} class="brand" aria-label={`${site.name} home`}>
      <span class="brand__row">
        <span class="brand__rule"></span>
        <span class="brand__name">CHITOWN</span>
        <span class="brand__rule brand__rule--r"></span>
      </span>
      <span class="brand__sub">TROLLEY</span>
    </a>

    <!-- Below ~1024px this whole block becomes a slide-in drawer (see the
         max-width media query) — `display:contents` keeps it a no-op wrapper
         at desktop widths so today's inline flex layout is untouched there. -->
    <div
      class="hdr__panel"
      id="hdr-mobile-panel"
      data-mobile-menu
      aria-label="Mobile navigation"
    >
      <nav class="nav" aria-label="Main">
        {navMain.map((n) => (
          <a
            href={withBase(n.href)}
            class:list={['nav__link', { active: isActive(n.href) }]}
            aria-current={isActive(n.href) ? 'page' : undefined}
          >
            {n.labelParts
              ? n.labelParts.map((part) => (
                  <span class={part.className}>{part.text} </span>
                ))
              : n.label}
          </a>
        ))}

        <div class="more" data-more-menu>
          <button
            type="button"
            class:list={['nav__link', 'more__btn', { active: moreActive }]}
            aria-expanded="false"
            aria-haspopup="true"
            data-more-toggle
          >
            More
            <svg class="more__caret" width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"></polyline></svg>
          </button>
          <div class="more__menu" data-more-panel hidden>
            {navMore.map((n) => (
              <a
                href={withBase(n.href)}
                class:list={['more__item', { active: isActive(n.href) }]}
                aria-current={isActive(n.href) ? 'page' : undefined}
              >{n.label}</a>
            ))}
          </div>
        </div>
      </nav>

      <div class="hdr__cta">
        <a href={withBase(site.routes.reservation)} class="btn-gold btn-gold--sm">Reservation</a>
      </div>
    </div>

    <button
      type="button"
      class="hdr__burger"
      data-mobile-menu-toggle
      aria-expanded="false"
      aria-controls="hdr-mobile-panel"
      aria-label="Open menu"
    >
      <span class="hdr__burger-line" aria-hidden="true"></span>
      <span class="hdr__burger-line" aria-hidden="true"></span>
      <span class="hdr__burger-line" aria-hidden="true"></span>
    </button>
  </div>

  <div
    class="hdr__backdrop"
    data-mobile-menu-backdrop
    aria-hidden="true"
  ></div>
</header>

<style>
  .hdr {
    position: sticky;
    top: 0;
    z-index: 60;
    isolation: isolate;
    background: transparent;
    border-bottom: 1px solid var(--line);
  }
  /* Keep the translucent header treatment off the element that contains the
     fixed drawer. A backdrop filter on that ancestor can make fixed
     descendants use the header as their containing block. */
  .hdr::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    background: rgba(253, 252, 250, .92);
    -webkit-backdrop-filter: blur(10px);
    backdrop-filter: blur(10px);
    pointer-events: none;
  }
  .hdr.is-menu-open {
    z-index: 900;
  }
  .hdr__inner {
    padding-block: 12px;
    min-height: 52px;
    display: flex;
    flex-wrap: nowrap;
    align-items: center;
    justify-content: space-between;
    gap: clamp(8px, 1.6vw, 20px);
  }

  /* Brand / logo */
  .brand {
    display: flex; flex-direction: column; align-items: center; gap: 2px;
    text-decoration: none; color: var(--ink); flex: none;
  }
  .brand__row { display: flex; align-items: center; gap: clamp(5px, .8vw, 10px); }
  .brand__rule { display: block; width: clamp(14px, 2.1vw, 26px); height: 1px; background: linear-gradient(90deg, transparent, var(--gold-dark)); }
  .brand__rule--r { background: linear-gradient(90deg, var(--gold-dark), transparent); }
  .brand__name { font-family: var(--serif); font-weight: 600; font-size: clamp(15.5px, 1.7vw, 21px); letter-spacing: .14em; line-height: 1; }
  .brand__sub { font-size: clamp(7.5px, .77vw, 9.5px); letter-spacing: .44em; color: var(--gold-dark); font-weight: 500; margin-left: .44em; }

  /* Nav */
  .nav {
    display: flex; flex-wrap: nowrap; gap: clamp(10px, 1.75vw, 22px);
    align-items: center; justify-content: center; min-width: 0;
  }
  .nav__link {
    all: unset;
    box-sizing: border-box;
    cursor: pointer;
    font-family: var(--sans);
    font-size: 12px; letter-spacing: .16em; font-weight: 400;
    text-transform: uppercase; text-decoration: none;
    padding: 4px 0; white-space: nowrap;
    color: var(--ink);
    border-bottom: 1px solid transparent;
    transition: color .25s ease;
  }
  .nav__link:hover { color: var(--gold-dark); }
  .nav__link.active { color: var(--gold-deep); border-bottom-color: var(--gold); }
  .nav__link:focus-visible,
  .more__item:focus-visible,
  .hdr__burger:focus-visible {
    outline: 2px solid var(--gold-dark);
    outline-offset: 4px;
  }

  /* Festive "Christmas Trolley" link — keeps its colors on hover/active.
     :global() is required because the class names come from shared nav data. */
  .nav__link :global(.xmas-c) { color: #00BF4C; }
  .nav__link :global(.xmas-t) { color: #C8102E; }

  /* More dropdown */
  .more { position: relative; }
  .more__btn { display: flex; align-items: center; gap: 7px; }
  .more__caret { transition: transform .25s ease; }
  .more.open .more__caret { transform: rotate(180deg); }
  .more__menu {
    position: absolute; top: calc(100% + 19.5px); left: 50%; transform: translateX(-50%);
    background: var(--paper);
    border: 1px solid var(--line);
    border-top: 2px solid var(--gold);
    box-shadow: 0 14px 40px rgba(26, 26, 26, .12);
    min-width: 190px;
    display: flex; flex-direction: column;
    padding: 8px 0; z-index: 70;
  }
  .more__item {
    font-size: 11.5px; letter-spacing: .16em; font-weight: 400;
    text-decoration: none; text-transform: uppercase;
    padding: 11px 22px; white-space: nowrap;
    color: var(--ink);
    transition: color .2s ease, background .2s ease;
  }
  .more__item:hover { color: var(--gold-deep); background: var(--cream); }
  .more__item.active { color: var(--gold-deep); }

  .hdr__cta { display: flex; align-items: center; gap: 20px; flex: none; }

  /* Hamburger (hidden on desktop — the panel stays inline there via `contents`) */
  .hdr__burger {
    display: none;
    position: relative; z-index: 66; flex: none;
    width: 44px; height: 44px; margin-left: 8px;
    background: transparent; border: 0; cursor: pointer; padding: 0;
    flex-direction: column; align-items: center; justify-content: center; gap: 5px;
  }
  .hdr__burger-line {
    display: block; width: 22px; height: 1.5px; background: var(--ink);
    transition: transform .25s ease, opacity .25s ease;
  }
  .hdr.is-menu-open .hdr__burger-line:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
  .hdr.is-menu-open .hdr__burger-line:nth-child(2) { opacity: 0; }
  .hdr.is-menu-open .hdr__burger-line:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

  /* Backdrop behind the mobile drawer */
  .hdr__backdrop {
    display: none;
  }

  /* On desktop the panel is an invisible wrapper — nav + reservation button
     keep flowing inline in .hdr__inner exactly as before this change. */
  .hdr__panel { display: contents; }

  @media (max-width: 1023px) {
    .hdr__burger {
      display: flex;
      z-index: 920;
    }

    .hdr__backdrop {
      display: block;
      position: fixed;
      inset: 0;
      width: 100%;
      height: 100vh;
      height: 100dvh;
      z-index: 900;
      background: rgba(0, 0, 0, .72);
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
      transition: opacity 220ms ease, visibility 0s linear 220ms;
    }
    .hdr.is-menu-open .hdr__backdrop {
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
      transition: opacity 220ms ease, visibility 0s linear 0s;
    }

    /* The panel becomes the real slide-in drawer. */
    .hdr__panel {
      display: flex;
      flex-direction: column;
      align-items: stretch;
      position: fixed;
      top: 0;
      right: 0;
      bottom: 0;
      z-index: 910;
      width: min(86vw, 360px);
      height: 100vh;
      height: 100dvh;
      background: var(--paper);
      padding:
        calc(80px + env(safe-area-inset-top))
        calc(28px + env(safe-area-inset-right))
        calc(24px + env(safe-area-inset-bottom))
        28px;
      box-shadow: -16px 0 44px rgba(26, 26, 26, .18);
      transform: translate3d(100%, 0, 0);
      /* visibility (not just the off-screen transform) must gate the closed
         state — a fixed+transformed box alone can still get counted toward
         the document's scrollable width in some mobile browsers, which is
         what let the "closed" drawer be reached by scrolling sideways.
         visibility flips to hidden only after the slide-out transition
         finishes (transition-delay), so the close animation still plays. */
      visibility: hidden;
      pointer-events: none;
      transition:
        transform 260ms cubic-bezier(.22, 1, .36, 1),
        visibility 0s linear 260ms;
      overflow-y: auto;
      overflow-x: hidden;
      overscroll-behavior: contain;
      -webkit-overflow-scrolling: touch;
      will-change: transform;
    }
    .hdr.is-menu-open .hdr__panel {
      transform: translate3d(0, 0, 0);
      visibility: visible;
      pointer-events: auto;
      transition:
        transform 260ms cubic-bezier(.22, 1, .36, 1),
        visibility 0s linear 0s;
    }

    .nav {
      flex-direction: column; align-items: stretch; justify-content: flex-start;
      gap: 0; flex-wrap: nowrap;
    }
    .nav__link {
      width: 100%; padding: 13px 2px;
      font-size: 13px; letter-spacing: .14em;
      border-bottom: 1px solid var(--line);
    }
    .more { width: 100%; }
    .more__btn { width: 100%; justify-content: space-between; }
    /* Inline accordion instead of a floating dropdown, so it pushes the rest
       of the drawer down rather than overlapping it. */
    .more__menu {
      position: static; transform: none;
      border: 0; border-top: none; box-shadow: none;
      background: var(--cream);
      min-width: 0; width: 100%;
      padding: 4px 0 4px 18px;
    }
    .more__item { padding: 12px 4px; }

    .hdr__cta { width: 100%; margin-top: 22px; }
    .hdr__cta .btn-gold {
      display: flex; align-items: center; justify-content: center;
      width: 100%; min-height: 44px;
    }
  }

  @media (max-width: 1023px) and (prefers-reduced-motion: reduce) {
    .hdr__panel,
    .hdr__backdrop,
    .hdr__burger-line {
      transition-duration: 1ms;
    }
  }
</style>

<script>
  // "More" dropdown: toggle, close on outside click / Escape.
  const menu = document.querySelector<HTMLElement>('[data-more-menu]');
  const toggle = menu?.querySelector<HTMLButtonElement>('[data-more-toggle]');
  const panel = menu?.querySelector<HTMLElement>('[data-more-panel]');

  function setMoreOpen(open: boolean, restoreFocus = false) {
    if (!menu || !toggle || !panel) return;
    menu.classList.toggle('open', open);
    toggle.setAttribute('aria-expanded', String(open));
    panel.hidden = !open;
    if (!open && restoreFocus) toggle.focus();
  }

  toggle?.addEventListener('click', (e) => {
    e.stopPropagation();
    setMoreOpen(menu?.classList.contains('open') ? false : true);
  });
  document.addEventListener('click', (e) => {
    if (menu && !menu.contains(e.target as Node)) setMoreOpen(false);
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && menu?.classList.contains('open')) {
      e.preventDefault();
      setMoreOpen(false, true);
    }
  });
</script>

<script>
  // Mobile nav drawer: one state on the shared header controls the toggle,
  // backdrop, drawer, accessibility attributes, and page scroll lock.
  const siteHeader = document.querySelector<HTMLElement>('[data-site-header]');
  const burger = document.querySelector<HTMLButtonElement>('[data-mobile-menu-toggle]');
  const navPanel = document.querySelector<HTMLElement>('[data-mobile-menu]');
  const menuBackdrop = document.querySelector<HTMLElement>('[data-mobile-menu-backdrop]');
  const desktopMq = window.matchMedia('(min-width: 1024px)');

  // Pin the body at its current scroll offset while the menu is open. This
  // prevents background bounce on iOS and restores the exact position later.
  let lockedScrollY = 0;

  const lockScroll = () => {
    if (document.documentElement.classList.contains('menu-open')) return;
    lockedScrollY = window.scrollY;
    document.documentElement.classList.add('menu-open');
    document.body.style.top = `-${lockedScrollY}px`;
  };

  const unlockScroll = () => {
    if (!document.documentElement.classList.contains('menu-open')) return;
    document.documentElement.classList.remove('menu-open');
    document.body.style.top = '';
    window.scrollTo(0, lockedScrollY);
  };

  const isMenuOpen = () => siteHeader?.classList.contains('is-menu-open') ?? false;

  const getDrawerFocusables = () => {
    const panelFocusables = navPanel
      ? Array.from(
          navPanel.querySelectorAll<HTMLElement>(
            'a[href], button:not([disabled]), [tabindex]:not([tabindex="-1"])',
          ),
        ).filter((element) => !element.closest('[hidden]'))
      : [];
    return burger ? [...panelFocusables, burger] : panelFocusables;
  };

  const setMenuOpen = (open: boolean, restoreFocus = true) => {
    if (!siteHeader || !burger || !navPanel || !menuBackdrop) return;

    // The panel is ordinary inline desktop navigation above this breakpoint.
    if (desktopMq.matches) open = false;

    const wasOpen = isMenuOpen();
    siteHeader.classList.toggle('is-menu-open', open);
    burger.setAttribute('aria-expanded', String(open));
    burger.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
    menuBackdrop.setAttribute('aria-hidden', String(!open));

    if (desktopMq.matches) {
      navPanel.removeAttribute('aria-hidden');
      navPanel.removeAttribute('inert');
    } else {
      navPanel.setAttribute('aria-hidden', String(!open));
      navPanel.toggleAttribute('inert', !open);
    }

    if (open && !wasOpen) {
      lockScroll();
      requestAnimationFrame(() => getDrawerFocusables()[0]?.focus());
    } else if (!open && wasOpen) {
      unlockScroll();
      if (restoreFocus) burger.focus();
    }
  };

  burger?.addEventListener('click', () => setMenuOpen(!isMenuOpen()));
  menuBackdrop?.addEventListener('click', () => setMenuOpen(false));
  document.addEventListener('keydown', (e) => {
    if (!isMenuOpen()) return;

    if (e.key === 'Escape') {
      setMenuOpen(false);
      return;
    }

    if (e.key === 'Tab') {
      const focusables = getDrawerFocusables();
      const first = focusables[0];
      const last = focusables.at(-1);
      if (!first || !last) return;

      if (e.shiftKey && document.activeElement === first) {
        e.preventDefault();
        last.focus();
      } else if (!e.shiftKey && document.activeElement === last) {
        e.preventDefault();
        first.focus();
      }
    }
  });
  navPanel
    ?.querySelectorAll('a')
    .forEach((a) =>
      a.addEventListener('click', () => {
        if (!desktopMq.matches) setMenuOpen(false, false);
      }),
    );

  // Drop all modal state on desktop; initialize mobile as closed and inert.
  const syncMenuForViewport = () => {
    setMenuOpen(false, false);
    if (!desktopMq.matches) {
      navPanel?.setAttribute('aria-hidden', 'true');
      navPanel?.setAttribute('inert', '');
    }
  };

  desktopMq.addEventListener('change', syncMenuForViewport);
  syncMenuForViewport();
</script>
