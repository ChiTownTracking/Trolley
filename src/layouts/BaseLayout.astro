---
import '../styles/global.css';
import TopBar from '../components/TopBar.astro';
import Header from '../components/Header.astro';
import CtaBand from '../components/CtaBand.astro';
import Footer from '../components/Footer.astro';
import { site } from '../data/site';
import { fleetImages } from '../data/fleet';
import { withBase } from '../utils/paths';
import type { ImageMetadata } from 'astro';
import jostNormalUrl from '../assets/fonts/jost/jost-latin-variable-normal.woff2?url';
import cormorantNormalUrl from '../assets/fonts/cormorant-garamond/cormorant-garamond-latin-variable-normal.woff2?url';
import cormorantItalicUrl from '../assets/fonts/cormorant-garamond/cormorant-garamond-latin-variable-italic.woff2?url';

interface Props {
  title?: string;
  description?: string;
  /** Hide the gold CTA band above the footer (e.g. on Contact/Reservation). */
  hideCta?: boolean;
  /** Root-relative or absolute og:image (e.g. an article's cover photo). */
  image?: string | ImageMetadata;
  /** og:type — pages like guide articles should pass 'article'. */
  ogType?: 'website' | 'article';
  /** Optional crawler directive for confirmed draft/utility pages. */
  robots?: 'index,follow' | 'noindex,follow';
  /** Optional JSON-LD object(s) injected as a <script type="application/ld+json">. */
  schema?: Record<string, unknown> | Record<string, unknown>[];
  /** Homepage-only mobile hero preload URL; the desktop hero remains unchanged. */
  mobileHeroPreload?: string;
  /** Disable only on routes whose initial viewport has no italic serif text. */
  preloadSerifItalic?: boolean;
}

const {
  title = `${site.name} — Chicago Wedding Trolley Transportation`,
  description = site.description,
  hideCta = false,
  image,
  ogType = 'website',
  robots,
  schema,
  mobileHeroPreload,
  preloadSerifItalic = true,
} = Astro.props;

const canonical = new URL(withBase(Astro.url.pathname), Astro.site ?? Astro.url).href;
const imagePath = typeof image === 'string' ? withBase(image) : image?.src;
const ogImage = imagePath ? new URL(imagePath, Astro.site ?? Astro.url).href : undefined;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  {robots && <meta name="robots" content={robots} />}
  <link rel="canonical" href={canonical} />
  <meta property="og:type" content={ogType} />
  <meta property="og:url" content={canonical} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  {ogImage && <meta property="og:image" content={ogImage} />}
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="theme-color" content="#FDFCFA" />
  {schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} is:inline />}
  <link rel="icon" href={fleetImages.trolley.frontThreeQuarterWebp.src} type="image/webp" />
  <link rel="preload" href={jostNormalUrl} as="font" type="font/woff2" crossorigin="anonymous" />
  <link rel="preload" href={cormorantNormalUrl} as="font" type="font/woff2" crossorigin="anonymous" />
  {preloadSerifItalic && (
    <link rel="preload" href={cormorantItalicUrl} as="font" type="font/woff2" crossorigin="anonymous" />
  )}
  {mobileHeroPreload && (
    <link
      rel="preload"
      as="image"
      href={mobileHeroPreload}
      type="image/webp"
      media="(max-width: 768px)"
      fetchpriority="high"
    />
  )}
</head>
<body>
  <a class="skip-link" href="#main-content">Skip to main content</a>
  <div class="site">
    <TopBar />
    <Header />
    <main id="main-content" tabindex="-1">
      <slot />
    </main>
    {!hideCta && <CtaBand />}
    <Footer />
  </div>

  <script>
    // Reveal-on-scroll for any .rv element on the page.
    const reveal = () => {
      const els = document.querySelectorAll<HTMLElement>('.rv:not(.in)');
      if (!('IntersectionObserver' in window)) {
        els.forEach((el) => el.classList.add('in'));
        return;
      }
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              e.target.classList.add('in');
              io.unobserve(e.target);
            }
          });
        },
        { threshold: 0.08, rootMargin: '0px 0px -40px 0px' },
      );
      els.forEach((el) => io.observe(el));
    };
    reveal();
  </script>
</body>
</html>
