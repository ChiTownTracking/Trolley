---
import BaseLayout from '../layouts/BaseLayout.astro';
import Eyebrow from '../components/Eyebrow.astro';
import GuideCard from '../components/GuideCard.astro';
import { getImage, Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import { testimonials, eventTypes, vehicleOptions, hoursOptions, homeFaqs, getLocalBusinessSchema } from '../data/site';
import { fleet } from '../data/fleet';
import { siteImages } from '../data/site-images';
import { withBase } from '../utils/paths';
import occasionsImage from '../assets/images/home/occasion/occasion.png';
import occasionsMobileImage from '../assets/images/home/occasion/occasion-mobile.png';

const passengerOptions = ['1–10', '11–20', '21–30', '31–40', '41–57'];

// Fleet grid: the first vehicle (Classic White Trolley) is the full-width
// featured card; the rest fill the 3-up row below it.
const [fleetFeatured, ...fleetRest] = fleet;
const featuredFleetWidths = [384, 512, 555];
const standardFleetWidths = [384, 512, 768, 900];
const featuredFleetSizes =
  '(max-width: 640px) calc(100vw - 20px), (max-width: 768px) calc(68.75vw - 13.75px), (max-width: 1100px) calc(68.75vw - 38.5px), 718px';
const standardFleetSizes =
  '(max-width: 640px) calc(100vw - 20px), (max-width: 768px) calc(50vw - 26px), (max-width: 900px) calc(50vw - 44px), (max-width: 1100px) calc(33.333vw - 40px), 327px';

// Guides preview: always the 3 most recently published articles.
const latestGuides = (await getCollection('guides'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const businessSchema = getLocalBusinessSchema(new URL(withBase('/'), Astro.site ?? Astro.url).href);
const mobileHero = await getImage({
  src: siteImages.homeHero.mobile,
  width: 900,
  format: 'webp',
  quality: 78,
});
const heroStyle = `--hero-desktop: url('${siteImages.homeHero.desktop.src}'); --hero-mobile: url('${mobileHero.src}')`;
const occasionsMobileWidths = [480, 768, 1024];
const occasionsMobileSources = await Promise.all(
  occasionsMobileWidths.map((width) =>
    getImage({
      src: occasionsMobileImage,
      width,
      format: 'webp',
      quality: 78,
    }),
  ),
);
const occasionsMobileSrcset = occasionsMobileSources
  .map((image, index) => `${image.src} ${occasionsMobileWidths[index]}w`)
  .join(', ');
---
<BaseLayout
  title="Chicago Trolley Rental for Weddings & Events | ChiTown Trolley"
  description="Book a Chicago trolley rental for weddings, private events and group transportation. Explore the ChiTown Trolley fleet and request a customized quote."
  schema={businessSchema}
  mobileHeroPreload={mobileHero.src}
>
  <!-- Hero -->
  <section class="hero" style={heroStyle}>
    <div class="hero__overlay"></div>
    <div class="hero__content">
      <h1 class="hero__title">
        <span class="hero__titleLine">Chicago Trolley Rental</span>{' '}
        <span class="hero__finalLine">
          <em class="hero__for">for</em>{' '}
          <em class="grad hero__wedding">Weddings &amp; Events</em>
        </span>
      </h1>
      <p class="hero__lead">
        Private trolley service for celebrations and coordinated group travel throughout Chicago and Chicagoland.
      </p>
      <span class="hero__divider" aria-hidden="true"><span></span><i></i></span>
      <div class="hero__ownership">
        <span class="hero__proudly">Proudly</span>
        <button
          type="button"
          class="hero__logoLink"
          data-certificate-open
          aria-haspopup="dialog"
          aria-controls="wbenc-certificate-dialog"
          aria-label="Open the WBENC certificate"
        >
          <span class="hero__logoCrop">
            <img
              class="hero__ownershipLogo"
              src={siteImages.branding.womenOwnedWordmark.src}
              width={siteImages.branding.womenOwnedWordmark.width}
              height={siteImages.branding.womenOwnedWordmark.height}
              alt="WBENC-certified Women Owned business"
            />
          </span>
        </button>
      </div>
      <a href={withBase(`/fleet/${fleetFeatured.slug}`)} class="btn-gold hero__cta">View Trolley</a>
    </div>
  </section>

  <dialog
    class="certificateModal"
    id="wbenc-certificate-dialog"
    data-certificate-dialog
    aria-label="WBENC certificate"
  >
    <div class="certificateModal__panel">
      <button
        type="button"
        class="certificateModal__close"
        data-certificate-close
        aria-label="Close certificate"
      >
        <span aria-hidden="true">&times;</span>
      </button>
      <img
        class="certificateModal__image"
        src={siteImages.branding.wbencCertificate.src}
        width={siteImages.branding.wbencCertificate.width}
        height={siteImages.branding.wbencCertificate.height}
        alt="WBENC National Women's Business Enterprise Certification for Sumadija Trans LLC doing business as ChiTown Limobus"
      />
    </div>
  </dialog>

  <!-- Get a Quote -->
  <section class="rv getquote" id="getquote">
    <div class="getquote__inner">
      <h2 class="h-section getquote__title">
        Request a <em class="grad">Chicago trolley rental quote</em>
      </h2>

      <form class="qform wizard" data-quote-form>
        <!-- Step 1 · Trip Information -->
        <div class="step is-open" data-step="1">
          <button type="button" class="step__head" data-step-toggle="1" aria-expanded="true">
            <span class="step__num"><span class="step__digit">1</span></span>
            <span class="step__label">
              <span class="step__kicker">Step 1 of 3</span>
              <span class="step__name">Trip Information</span>
            </span>
            <span class="step__chev" aria-hidden="true"></span>
          </button>
          <div class="step__panel">
            <div class="step__body">
              <div class="step__inner">
                <div class="step__grid">
                  <div class="qfield qfield--labeled">
                    <label class="qfield__label" for="event-type">Event Type</label>
                    <select id="event-type" name="type" class="field__control">
                      <option value="" disabled selected>Select event type</option>
                      {eventTypes.map((t) => <option>{t}</option>)}
                    </select>
                  </div>
                  <div class="qfield qfield--labeled">
                    <label class="qfield__label" for="number-of-hours">Number of Hours</label>
                    <select id="number-of-hours" name="hours" class="field__control">
                      <option value="" disabled selected>Select duration</option>
                      {hoursOptions.map((h) => <option>{h}</option>)}
                    </select>
                  </div>
                  <div class="qfield qfield--labeled">
                    <label class="qfield__label" for="vehicle">Vehicle</label>
                    <select id="vehicle" name="vehicle" class="field__control">
                      <option value="" disabled selected>Select vehicle</option>
                      {vehicleOptions.map((v) => <option>{v}</option>)}
                    </select>
                  </div>
                  <div class="qfield qfield--labeled">
                    <label class="qfield__label" for="number-of-passengers">Number of Passengers</label>
                    <select id="number-of-passengers" name="passengers" class="field__control">
                      <option value="" disabled selected>Select group size</option>
                      {passengerOptions.map((p) => <option>{p}</option>)}
                    </select>
                  </div>
                </div>
                <div class="step__nav">
                  <button type="button" class="btn-gold" data-step-next="2">Next</button>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Step 2 · Itinerary -->
        <div class="step" data-step="2">
          <button type="button" class="step__head" data-step-toggle="2" aria-expanded="false">
            <span class="step__num"><span class="step__digit">2</span></span>
            <span class="step__label">
              <span class="step__kicker">Step 2 of 3</span>
              <span class="step__name">Itinerary</span>
            </span>
            <span class="step__chev" aria-hidden="true"></span>
          </button>
          <div class="step__panel">
            <div class="step__body">
              <div class="step__inner">
                <div class="step__grid">
                  <div class="qfield qfield--labeled">
                    <label class="qfield__label" for="event-date">Event Date</label>
                    <input id="event-date" name="date" type="date" class="field__control" />
                  </div>
                  <div class="qfield qfield--labeled">
                    <label class="qfield__label" for="pickup-time">Pickup Time</label>
                    <input id="pickup-time" name="time" type="time" class="field__control" />
                  </div>
                  <div class="qfield qfield--labeled">
                    <label class="qfield__label" for="pickup-location">Pickup Location</label>
                    <input id="pickup-location" name="pickup" type="text" placeholder="Enter pickup address" class="field__control" />
                  </div>
                  <div class="qfield qfield--labeled">
                    <label class="qfield__label" for="destination">Destination</label>
                    <input id="destination" name="dropoff" type="text" placeholder="Enter destination" class="field__control" />
                  </div>
                </div>
                <div class="step__nav">
                  <button type="button" class="btn-ghost" data-step-back="1">Back</button>
                  <button type="button" class="btn-gold" data-step-next="3">Next</button>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Step 3 · Personal Info -->
        <div class="step" data-step="3">
          <button type="button" class="step__head" data-step-toggle="3" aria-expanded="false">
            <span class="step__num"><span class="step__digit">3</span></span>
            <span class="step__label">
              <span class="step__kicker">Step 3 of 3</span>
              <span class="step__name">Personal Info</span>
            </span>
            <span class="step__chev" aria-hidden="true"></span>
          </button>
          <div class="step__panel">
            <div class="step__body">
              <div class="step__inner">
                <div class="step__grid step__grid--3">
                  <div class="qfield qfield--labeled">
                    <label class="qfield__label" for="full-name">Full Name</label>
                    <input required id="full-name" name="name" type="text" placeholder="Enter your full name" class="field__control" />
                  </div>
                  <div class="qfield qfield--labeled">
                    <label class="qfield__label" for="phone-number">Phone Number</label>
                    <input required id="phone-number" name="phone" type="tel" placeholder="Enter your phone number" class="field__control" />
                  </div>
                  <div class="qfield qfield--labeled">
                    <label class="qfield__label" for="email-address">Email Address</label>
                    <input required id="email-address" name="email" type="email" placeholder="Enter your email address" class="field__control" />
                  </div>
                  <div class="qfield qfield--labeled qfield--wide">
                    <label class="qfield__label" for="referral-source">How Did You Find Us?</label>
                    <textarea id="referral-source" name="message" rows="2" placeholder="Tell us how you found us" class="field__control"></textarea>
                  </div>
                </div>
                <div class="step__nav">
                  <button type="button" class="btn-ghost" data-step-back="2">Back</button>
                  <button type="submit" class="btn-gold">Submit</button>
                </div>
              </div>
            </div>
          </div>
        </div>
        <p class="getquote__disclaimer">
          Chicago trolley rental prices vary by date, vehicle, rental duration, itinerary and pickup details.
          Share your plans for a customized estimate.
        </p>
      </form>

      <div class="confirm" data-quote-confirm role="alert" aria-labelledby="home-form-status-title" tabindex="-1" hidden>
        <span class="confirm__mark">✳</span>
        <p class="confirm__title" id="home-form-status-title">Online request not sent</p>
        <p class="confirm__body">No information was delivered. Online form integration is not configured yet; please use the contact information in the site header or footer.</p>
        <button type="button" class="link-gold" data-quote-reset>Return to form</button>
      </div>
    </div>
  </section>


  <!-- Fleet preview -->
  <section class="rv band">
    <div class="wrap">
      <Eyebrow label="The Fleet" mb={14} />
      <h2 class="h-section text-center fleetp__title">Explore our Chicago trolley and group transportation fleet</h2>
      <p class="fleetp__lead">
        Choose the classic white trolley for weddings and celebrations, or compare our additional vehicles for larger groups and longer itineraries.
      </p>
      <div class="fleetp__grid">
        {/* Row 1 — featured full-width trolley */}
        <a href={withBase(`/fleet/${fleetFeatured.slug}`)} class="fleet-card fleet-card--feature">
          <div class="fleet-card__media">
            <Image
              src={fleetFeatured.image}
              width={555}
              widths={featuredFleetWidths}
              sizes={featuredFleetSizes}
              format="webp"
              quality={78}
              loading="lazy"
              decoding="async"
              alt="Classic white trolley available for rental in Chicago"
              class="fleetp__img"
            />
          </div>
          <div class="fleetp__body">
            <p class="fleetp__cap">{fleetFeatured.previewCap}</p>
            <h3 class="fleetp__name">{fleetFeatured.name}</h3>
            <span class="link-gold fleetp__more">View Details →</span>
          </div>
        </a>
        {/* Row 2 — Coach, Party Bus, Limo Van */}
        {fleetRest.map((fl) => (
          <a href={withBase(`/fleet/${fl.slug}`)} class="fleet-card">
            <div class="fleet-card__media">
              <Image
                src={fl.image}
                width={900}
                widths={standardFleetWidths}
                sizes={standardFleetSizes}
                format="webp"
                quality={78}
                loading="lazy"
                decoding="async"
                alt={fl.name}
                class="fleetp__img"
              />
            </div>
            <div class="fleetp__body">
              <p class="fleetp__cap">{fl.previewCap}</p>
              <h3 class="fleetp__name">{fl.name}</h3>
            </div>
          </a>
        ))}
      </div>
      <div class="fleetp__cta">
        <a href={withBase('/fleet')} class="btn-gold">Explore the Full Fleet</a>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="rv tst">
    <div class="wrap">
      <Eyebrow label="Client Reviews" mb={14} />
      <h2 class="h-section text-center tst__title">
        What clients remember about ChiTown Trolley
      </h2>
      <div class="tstc" data-carousel>
        <button type="button" class="tstc__arrow" data-carousel-prev aria-label="Previous testimonial">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"></polyline></svg>
        </button>
        <div class="tstc__viewport">
          <div class="tstc__track" data-carousel-track>
            {testimonials.map((t) => {
              const [personName, personRole] = t.name.split('·').map((s) => s.trim());
              return (
                <figure class="quote tstc__slide">
                  <span class="quote__mark">“</span>
                  <blockquote class="quote__text">{t.quote}</blockquote>
                  <span class="quote__rule" aria-hidden="true"></span>
                  <figcaption class="quote__attribution">
                    <span class="quote__person">{personName}</span>
                    {personRole && <span class="quote__role">{personRole}</span>}
                  </figcaption>
                </figure>
              );
            })}
          </div>
        </div>
        <button type="button" class="tstc__arrow" data-carousel-next aria-label="Next testimonial">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"></polyline></svg>
        </button>
      </div>
      <div class="tstc__dots" data-carousel-dots aria-label="Testimonial navigation"></div>
    </div>
  </section>

  <section class="rv occasions" aria-labelledby="occasions-title">
    <div class="wrap occasions__grid">
      <div class="occasions__media">
        <picture class="occasions__picture">
          <source
            media="(max-width: 800px)"
            srcset={occasionsMobileSrcset}
            sizes="(max-width: 560px) calc(100vw - 36px), calc(100vw - 56px)"
            type="image/webp"
          />
          <Image
            src={occasionsImage}
            width={1024}
            widths={[480, 768, 1024]}
            sizes="560px"
            format="webp"
            quality={78}
            loading="lazy"
            decoding="async"
            alt="Guests traveling by private trolley for a Chicago event"
            class="occasions__image"
          />
        </picture>
      </div>

      <div class="occasions__content">
        <Eyebrow label="Private Trolley Transportation" mb={12} />

        <h2 class="h-section occasions__title" id="occasions-title">
          Private trolley service for the moments between destinations
        </h2>

        <p class="occasions__lead">
          From wedding parties and milestone celebrations to organized group outings,
          ChiTown Trolley keeps everyone together between stops. Share your route, timing
          and group size, and we will help match your plans with the right vehicle for
          private service throughout Chicago and Chicagoland.
        </p>

        <div class="occasions__list">
          <article class="occasion">
            <h3 class="occasion__title">
              <a href={withBase('/weddings')} class="occasion__link">Weddings</a>
            </h3>
            <p class="occasion__body">
              Keep the wedding party together between hotels, photo locations, the ceremony and the reception.
            </p>
          </article>

          <article class="occasion">
            <h3 class="occasion__title">
              <a href={withBase('/services')} class="occasion__link">Private Events</a>
            </h3>
            <p class="occasion__body">
              Keep guests together for birthdays, anniversaries, family celebrations and other private occasions.
            </p>
          </article>

          <article class="occasion">
            <h3 class="occasion__title">
              <a href={withBase('/services')} class="occasion__link">Group Travel</a>
            </h3>
            <p class="occasion__body">
              Coordinate hotel pickups, venue transfers and multiple stops with one clear itinerary.
            </p>
          </article>

          <article class="occasion">
            <h3 class="occasion__title">Local Service</h3>
            <p class="occasion__body">
              Work with an owner-operated, licensed and insured, WBENC-certified Women Owned company.
            </p>
          </article>
        </div>

        <a href="#getquote" class="btn-gold occasions__cta">
          Plan Your Transportation
        </a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="rv faq">
    <div class="wrap">
      <Eyebrow label="Common Questions" mb={14} />
      <h2 class="h-section text-center faq__title">
        Questions before you book
      </h2>

      <div class="faq__list" data-faq>
        {homeFaqs.map((f) => (
          <div class="faq__item">
            <button type="button" class="faq__head" aria-expanded="false" data-faq-toggle>
              <span class="faq__q">{f.q}</span>
              <span class="faq__chev" aria-hidden="true"></span>
            </button>
            <div class="faq__panel">
              <div class="faq__body">
                <p class="faq__a">{f.a}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Guides preview -->
  <section class="rv guidesp">
    <div class="wrap">
      <Eyebrow label="The Journal" mb={14} />
      <h2 class="h-section text-center guidesp__title">
        Trolley and group transportation <em class="grad">guides</em>
      </h2>
      <p class="guidesp__lead">
        Practical resources for planning routes, timing, vehicles and group travel throughout Chicago and Chicagoland.
      </p>
      <div class="guidesp__grid">
        {latestGuides.map((g) => (
          <GuideCard
            href={withBase(`/guides/${g.id}`)}
            image={g.data.cover}
            imageAlt={g.data.coverAlt}
            category={g.data.category}
            title={g.data.title}
            excerpt={g.data.excerpt}
            date={g.data.date}
            readTime={g.data.readTime}
          />
        ))}
      </div>
      <div class="guidesp__cta">
        <a href={withBase('/guides')} class="btn-ghost">View All Guides</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero */
  .hero {
    position: relative;
    height: 550px; /* fixed — stays consistent regardless of viewport height */
    overflow: hidden;
    background: #1b1813 var(--hero-desktop) center / cover no-repeat;
  }
  /* Dark-to-transparent gradient on the left for white-text legibility */
  .hero__overlay {
    position: absolute; inset: 0;
    pointer-events: none;
    background: linear-gradient(
      90deg,
      rgba(15, 12, 8, .82) 0%,
      rgba(15, 12, 8, .55) 32%,
      rgba(15, 12, 8, .18) 58%,
      rgba(15, 12, 8, 0) 80%
    );
  }
  .hero__content {
    position: relative; z-index: 2;
    display: flex; flex-direction: column; align-items: flex-start; justify-content: flex-start;
    text-align: left; gap: 0;
    max-width: 1400px; 
    margin-top: 80px;
    padding: 0 clamp(24px, 6vw, 96px);
    
    animation: fadeInUp 1.1s cubic-bezier(.22, .6, .2, 1) both;
  }
  .hero__title {
    font-family: var(--serif); font-weight: 400; color: #fff;
    font-size: clamp(34px, 5vw, 60px); line-height: 1.08;
    margin: 0; text-shadow: 0 2px 26px rgba(0, 0, 0, .38);
  }
  .hero__titleLine, .hero__finalLine { display: block; }
  .hero__for { font-style: italic; }
  .hero__finalLine { white-space: nowrap; }
  .hero__lead {
    max-width: 52ch;
    margin: 18px 0 0;
    color: rgba(255, 255, 255, .9);
    font-size: clamp(14px, 1.5vw, 17px);
    line-height: 1.65;
    font-weight: 300;
    text-shadow: 0 2px 18px rgba(0, 0, 0, .42);
  }
  .hero__divider { display: flex; align-items: center; gap: 11px; margin: 22px 0; }
  .hero__divider span { width: 90px; height: 1px; background: var(--gold); }
  .hero__divider i { width: 7px; height: 7px; background: var(--gold); transform: rotate(45deg); }
  .hero__ownership {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 7px;
  }
  .hero__proudly {
    color: var(--gold);
    font-size: 13px;
    font-weight: 600;
    line-height: 1;
    letter-spacing: .32em;
    text-transform: uppercase;
    text-shadow: 0 2px 18px rgba(0, 0, 0, .48);
  }
  .hero__logoCrop {
    position: relative;
    display: block;
    width: clamp(120px, 13vw, 155px);
    aspect-ratio: 515 / 216;
    overflow: hidden;
  }
  .hero__logoLink {
    display: block;
    padding: 0;
    border: 0;
    background: transparent;
    cursor: pointer;
  }
  .hero__logoLink:focus-visible {
    border-radius: 2px;
    outline: 2px solid var(--gold-light);
    outline-offset: 4px;
  }
  .hero__ownershipLogo {
    position: absolute;
    top: -32%;
    left: -3%;
    display: block;
    width: 106%;
    max-width: none;
    height: auto;
    filter: invert(1) hue-rotate(180deg) saturate(1.08) brightness(1.08);
  }
  .hero__cta {
    align-self: flex-start; display: inline-flex; align-items: center;
    min-height: 38px; padding: 9px 24px; margin-top: 22px;
    font-size: 11.5px; letter-spacing: .2em;
  }
  .hero__cta:focus-visible { outline: 2px solid var(--gold-light); outline-offset: 4px; }

  .certificateModal {
    width: min(92vw, 620px, 110svh);
    max-width: none;
    max-height: 90svh;
    padding: 0;
    border: 0;
    background: transparent;
    overflow: visible;
  }
  .certificateModal::backdrop {
    background: rgba(8, 7, 5, .82);
    backdrop-filter: blur(3px);
  }
  .certificateModal__panel {
    position: relative;
    padding: clamp(12px, 2.5vw, 22px);
    background: #fff;
    box-shadow: 0 24px 80px rgba(0, 0, 0, .48);
  }
  .certificateModal__image {
    display: block;
    width: 100%;
    height: auto;
  }
  .certificateModal__close {
    position: absolute;
    top: -14px;
    right: -14px;
    display: grid;
    width: 38px;
    height: 38px;
    padding: 0;
    border: 1px solid rgba(255, 255, 255, .45);
    border-radius: 50%;
    background: #171512;
    color: #fff;
    font: 300 28px/1 var(--sans);
    cursor: pointer;
    place-items: center;
  }
  .certificateModal__close:hover { color: var(--gold-light); }
  .certificateModal__close:focus-visible {
    outline: 2px solid var(--gold-light);
    outline-offset: 3px;
  }

  @media (max-width: 480px) {
    .certificateModal__close {
      top: 6px;
      right: 6px;
    }
  }

  @media (max-width: 768px) {
    .hero {
      height: auto;
      min-height: clamp(380px, 56svh, 440px);
      background-image: var(--hero-mobile);
      background-position: 66% center;
      background-size: cover;
    }

    .hero::after {
      position: absolute;
      z-index: 3;
      right: -10%;
      bottom: -22px;
      left: -10%;
      height: 44px;
      border-radius: 50% 50% 0 0 / 100% 100% 0 0;
      background: var(--paper);
      content: '';
      pointer-events: none;
    }

    .hero__overlay {
      background:
        linear-gradient(0deg, rgba(8, 8, 8, .32) 0%, rgba(8, 8, 8, 0) 34%),
        linear-gradient(
          90deg,
          rgba(10, 10, 10, .88) 0%,
          rgba(10, 10, 10, .72) 38%,
          rgba(10, 10, 10, .28) 70%,
          rgba(10, 10, 10, .08) 100%
        );
    }

    .hero__content {
      width: min(82%, 420px);
      min-height: inherit;
      padding: 50px 24px 55px;
      margin: 0;
      gap: 0;
    }

    .hero__title {
      width: 100%;
      font-size: clamp(2.15rem, 8.5vw, 3.25rem);
      line-height: .98;
      text-wrap: balance;
    }
    .hero__finalLine { white-space: normal; }

    .hero__lead {
      max-width: 34ch;
      margin-top: 14px;
      font-size: 13.5px;
      line-height: 1.55;
    }

    .hero__divider {
      margin: 18px 0;
    }

    .hero__ownership {
      gap: 6px;
    }

    .hero__proudly {
      font-size: 12px;
    }

    .hero__logoCrop {
      width: clamp(110px, 35vw, 130px);
    }

    .hero__cta {
      justify-content: center;
      width: auto;
      min-width: 124px;
      min-height: 32px;
      padding: 4px 10px;
      margin-top: 14px;
      font-size: 10.5px;
      letter-spacing: .18em;
      text-align: center;
    }
  }

  @media (max-width: 360px) {
    .hero__content { width: 100%; }
    .hero__title { width: 100%; font-size: 2.15rem; }
    .hero__divider span { width: 76px; }
    .hero__cta { letter-spacing: .16em; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__content { animation: none; }
  }

  /* Shared section helpers */
  .band { background: var(--cream); padding: 35px 5px; }

  /* Get a Quote — multi-step wizard */
  .getquote { padding: 40px 0 48px; }
  .getquote__inner { margin: 0 auto; padding-inline: clamp(20px, 4vw, 72px); }
  .getquote__title { margin: 0 0 28px; text-align: left; }
  .getquote__disclaimer {
    max-width: 78ch;
    margin: 18px 4px 0;
    color: var(--muted);
    font-size: 12.5px;
    font-weight: 300;
    line-height: 1.65;
    opacity: .78;
  }

  @media (max-width: 768px) {
    .getquote { padding: 25px 0 48px; }
    .getquote__title {
      margin-inline: -12px;
      font-size: clamp(17px, 5.75vw, 28px);
      line-height: 1.15;
      letter-spacing: -.025em;
      text-align: center;
      white-space: nowrap;
    }
    .getquote__disclaimer {
      margin-top: 16px;
      font-size: 12px;
      line-height: 1.6;
    }
  }

  .wizard { display: flex; flex-direction: column; }
  .qform .field__control { width: 100%; }
  .qform ::placeholder { color: var(--muted); opacity: .75; }
  .qform select.field__control:has(option:disabled:checked) { color: var(--muted); }

  .qfield--labeled {
    display: grid;
    grid-template-rows: auto minmax(42px, auto);
    align-content: end;
    min-width: 0;
  }
  .qfield--wide {
    grid-column: 1 / -1;
  }
  .qfield__label {
    display: block;
    min-height: 14px;
    margin: 0 0 7px;
    color: var(--muted);
    font-family: var(--sans);
    font-size: 11px;
    font-weight: 500;
    line-height: 1.2;
    letter-spacing: .08em;
    text-align: left;
    text-transform: uppercase;
  }
  .qfield--labeled input,
  .qfield--labeled select {
    box-sizing: border-box;
    width: 100%;
    min-width: 0;
    height: 42px;
    margin: 0;
    padding-top: 0;
    padding-bottom: 0;
  }
  .qfield--labeled textarea {
    box-sizing: border-box;
    width: 100%;
    min-width: 0;
    min-height: 96px;
    height: auto;
    margin: 0;
    resize: vertical;
  }
  .qfield--labeled input[type="date"],
  .qfield--labeled input[type="time"] {
    appearance: auto;
    -webkit-appearance: auto;
  }
  .qfield--labeled input[type="date"]::-webkit-date-and-time-value,
  .qfield--labeled input[type="time"]::-webkit-date-and-time-value {
    min-height: 1.2em;
    text-align: left;
  }

  /* Step shell */
  .step { border-bottom: 1px solid var(--line-2); }
  .step__head {
    width: 100%; display: flex; align-items: center; gap: 18px;
    padding: 22px 4px; background: transparent; border: 0; cursor: pointer;
    text-align: left; font-family: var(--sans); color: var(--ink);
  }
  .step__num {
    position: relative; flex: none; width: 36px; height: 36px; border-radius: 50%;
    border: 1px solid var(--gold); color: var(--gold-deep);
    font-family: var(--serif); font-size: 18px;
    transition: background .25s ease, color .25s ease, border-color .25s ease;
  }
  /* Absolute-centered numeral — immune to serif baseline quirks */
  .step__digit { position: absolute; top: 43%; left: 50%; transform: translate(-50%, -50%); line-height: 1; }
  .step.is-open .step__num { background: var(--grad-gold); color: #fff;  }
  .step.is-done:not(.is-open) .step__num { background: var(--gold-deep); color: #fff; border-color: transparent; }
  .step__label { display: flex; flex-direction: column; gap: 3px; }
  .step__kicker { font-size: 10.5px; letter-spacing: .28em; text-transform: uppercase; color: var(--gold-deep); }
  .step__name { font-family: var(--serif); font-size: 21px; font-weight: 600; line-height: 1.05; color: var(--ink); }
  .step__chev {
    margin-left: auto; flex: none; width: 9px; height: 9px;
    border-right: 1.5px solid var(--gold-deep); border-bottom: 1.5px solid var(--gold-deep);
    transform: translateY(-2px) rotate(45deg); transition: transform .3s ease;
  }
  .step.is-open .step__chev { transform: translateY(2px) rotate(-135deg); }

  /* Collapsible panel — animated height via grid-rows 0fr → 1fr */
  .step__panel { display: grid; grid-template-rows: 0fr; transition: grid-template-rows .35s ease; }
  .step.is-open .step__panel { grid-template-rows: 1fr; }
  .step__body { overflow: hidden; min-height: 0; }
  .step__inner { padding: 2px 4px 30px; }

  .step__grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px 22px; }
  .step__grid--3 { grid-template-columns: repeat(3, 1fr); }
  .step__nav { display: flex; align-items: center; justify-content: flex-end; gap: 14px; margin-top: 26px; }
  /* Slimmer nav buttons (scoped — leaves the global .btn-gold untouched).
     min-height (rather than relying on padding + line-height math) guarantees
     a real 44px tap target regardless of font metrics. */
  .step__nav .btn-gold {
    padding: 11px 30px; font-size: 11.5px; letter-spacing: .22em; box-shadow: none;
    min-height: 44px; display: inline-flex; align-items: center;
  }
  /* Slim the ghost "Back" button to match the slimmed Next in the wizard nav
     (the base .btn-ghost lives in global.css). */
  .step__nav .btn-ghost {
    padding: 10px 29px; font-size: 11.5px; letter-spacing: .22em;
    min-height: 44px; display: inline-flex; align-items: center;
  }

  .confirm { display: flex; flex-direction: column; align-items: flex-start; gap: 14px; }
  .confirm__mark {
    font-family: var(--serif); font-size: 40px; line-height: 1;
    background: linear-gradient(100deg, var(--gold-dark), var(--gold));
    -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;
  }
  .confirm__title { font-family: var(--serif); font-size: 28px; font-weight: 600; margin: 0; }
  .confirm__body { font-weight: 300; font-size: 15px; line-height: 1.8; color: var(--muted); margin: 0; max-width: 46ch; }

  /* 4/3 cols → 2 on tablet → 1 on mobile */
  @media (max-width: 900px) {
    .step__grid, .step__grid--3 { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 560px) {
    .step__grid, .step__grid--3 { grid-template-columns: 1fr; }
    .step__head { gap: 14px; padding: 18px 2px; }
    .step__name { font-size: 19px; }
  }
  @media (prefers-reduced-motion: reduce) {
    .step__panel, .step__chev, .step__num { transition: none; }
  }

  /* Services strip */
  .strip { padding: 80px 28px; text-align: center; }
  .strip__chips { display: flex; flex-wrap: wrap; justify-content: center; gap: 12px 14px; }

  /* Fleet preview — elevated cards */
  .fleetp__title { margin-bottom: 14px; }
  .fleetp__lead {
    max-width: 64ch;
    margin: 0 auto 46px;
    text-align: center;
    color: var(--muted);
    font-size: 15px;
    font-weight: 300;
    line-height: 1.7;
  }
  .fleetp__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; }
  .fleet-card {
    display: block; text-decoration: none; color: inherit;
    background: var(--paper);
    border: 1px solid var(--line-2);
    box-shadow: 0 2px 10px rgba(26, 26, 26, .04);
    overflow: hidden;
    transition: box-shadow .35s ease, transform .35s ease, border-color .35s ease;
  }
  .fleet-card:hover { transform: translateY(-4px); box-shadow: 0 18px 44px rgba(26, 26, 26, .14); border-color: var(--gold-cream); }
  .fleet-card__media { position: relative; overflow: hidden; }
  .fleetp__img { width: 100%; height: 260px; object-fit: cover; display: block; transition: transform .6s cubic-bezier(.22, .6, .2, 1); }
  .fleet-card:hover .fleetp__img { transform: scale(1.05); }
  .fleetp__body { padding: 22px 26px 26px; text-align: center; }
  .fleetp__cap { font-size: 11px; letter-spacing: .24em; text-transform: uppercase; color: var(--gold-deep); margin: 0 0 8px; }
  .fleetp__name {
    font-family: var(--serif); font-size: 25px; font-weight: 600; margin: 0;
    position: relative; display: inline-block; padding-bottom: 7px;
  }
  .fleetp__name::after {
    content: ''; position: absolute; left: 50%; bottom: 0; transform: translateX(-50%);
    width: 0; height: 2px; background: var(--grad-gold); transition: width .35s ease;
  }
  .fleet-card:hover .fleetp__name::after { width: 44px; }
  .fleetp__cta { text-align: center; margin-top: 48px; }
  .fleetp__more { display: none; }

  /* Featured full-width trolley — landscape layout (image | content) */
  .fleet-card--feature {
    grid-column: 1 / -1;
    display: grid; grid-template-columns: 2.2fr 1fr; align-items: stretch;
  }
  .fleet-card--feature .fleet-card__media { height: 100%; min-height: clamp(320px, 34vw, 400px); }
  .fleet-card--feature .fleetp__img { height: 100%; }
  .fleet-card--feature .fleetp__body {
    text-align: left; display: flex; flex-direction: column;
    justify-content: center; align-items: flex-start;
    padding: 40px clamp(32px, 4vw, 60px);
  }
  .fleet-card--feature .fleetp__cap { margin: 0 0 12px; }
  .fleet-card--feature .fleetp__name { font-size: clamp(30px, 3.2vw, 40px); }
  .fleet-card--feature .fleetp__name::after { left: 0; transform: none; }
  .fleet-card--feature .fleetp__more { display: inline-block; margin-top: 24px; }

  /* Touch devices (no hover): reveal the gold accent by default. */
  @media (hover: none) {
    .fleetp__name::after { width: 44px; }
  }
  /* Tablet: row 2 collapses to 2 columns (feature stays full width) */
  @media (max-width: 900px) {
    .fleetp__grid { grid-template-columns: repeat(2, 1fr); }
  }
  /* Mobile: everything stacks, feature card becomes image-over-content */
  @media (max-width: 640px) {
    .fleetp__grid { grid-template-columns: 1fr; }
    .fleet-card { border-radius: 5px; overflow: hidden; }
    .fleet-card--feature { grid-template-columns: 1fr; }
    .fleet-card--feature .fleet-card__media { min-height: 240px; }
    .fleet-card--feature .fleetp__body { padding: 26px 26px 30px; }
  }

  /* Image-led occasions overview */
  .occasions {
    padding: 0 28px 56px;
    background: var(--paper);
  }
  .occasions__grid {
    display: grid;
    grid-template-columns: minmax(0, .95fr) minmax(0, 1.05fr);
    align-items: stretch;
    max-width: 1180px;
    min-height: 470px;
  }
  .occasions__media {
    min-height: 470px;
    overflow: hidden;
  }
  .occasions__picture {
    display: block;
    width: 100%;
    height: 100%;
  }
  .occasions__image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .occasions__content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: clamp(36px, 5vw, 68px);
    background: var(--cream);
  }
  .occasions__content :global(.eyebrow) {
    display: grid;
    grid-template-columns: minmax(24px, 1fr) auto minmax(24px, 1fr);
    width: 100%;
    gap: 16px;
  }
  .occasions__content :global(.eyebrow__rule) {
    width: 100% !important;
  }
  .occasions__content :global(.eyebrow__label) {
    line-height: 1.55;
    text-align: center;
  }
  .occasions__title {
    max-width: 16ch;
    margin: 0 0 18px;
    text-align: left;
  }
  .occasions__lead {
    max-width: 62ch;
    margin: 0;
    color: var(--muted);
    font-size: 15px;
    font-weight: 300;
    line-height: 1.75;
  }
  .occasions__list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0 28px;
    margin-top: 30px;
  }
  .occasion {
    padding: 18px 0;
    border-top: 1px solid var(--line-2);
  }
  .occasion__title {
    margin: 0 0 7px;
    font-family: var(--serif);
    font-size: 18px;
    font-weight: 600;
  }
  .occasion__link {
    color: inherit;
    text-decoration: none;
  }
  .occasion__link:hover {
    color: var(--gold-dark);
  }
  .occasion__link:focus-visible {
    border-radius: 2px;
    outline: 2px solid var(--gold);
    outline-offset: 3px;
  }
  .occasion__body {
    margin: 0;
    color: var(--muted);
    font-size: 13.5px;
    font-weight: 300;
    line-height: 1.65;
  }
  .occasions__cta {
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    margin-top: 26px;
  }

  @media (max-width: 800px) {
    .occasions__grid {
      grid-template-columns: 1fr;
      min-height: 0;
    }
    .occasions__media { min-height: 320px; }
    .occasions__content { padding: 38px 30px 42px; }
    .occasions__title { max-width: 20ch; }
  }

  @media (max-width: 560px) {
    .occasions { padding: 0 18px 42px; }
    .occasions__media { min-height: 250px; }
    .occasions__content { padding: 32px 22px 36px; }
    .occasions__content :global(.eyebrow) {
      grid-template-columns: minmax(20px, 1fr) minmax(0, 22ch) minmax(20px, 1fr);
      gap: 12px;
    }
    .occasions__list {
      grid-template-columns: 1fr;
      margin-top: 24px;
    }
  }

  /* Testimonials carousel */
  .tst { padding: 48px 5px; }
  .tst__title { margin: 0 auto 34px; }
  .tstc { display: flex; align-items: center; gap: 12px; max-width: 900px; margin: 0 auto; }
  .tstc__viewport { flex: 1 1 auto; min-width: 0; overflow: hidden; }
  .tstc__track { display: flex; transition: transform .6s cubic-bezier(.22, .6, .2, 1); }
  .tstc__slide { flex: 0 0 100%; padding: 0 14px; }
  .tstc__arrow {
    flex: none; cursor: pointer; background: none; border: 0; padding: 8px; line-height: 0;
    min-width: 44px; min-height: 44px; display: inline-flex; align-items: center; justify-content: center;
    color: var(--gold-deep); border-radius: 50%;
    transition: color .25s ease, background .25s ease;
  }
  .tstc__arrow:hover { color: var(--gold-dark); background: var(--cream); }
  .tstc__arrow svg { width: 26px; height: 26px; }
  .tstc__dots { display: flex; justify-content: center; align-items: center; gap: 8px; }
  /* The bar buttons are created in JS, so they never receive Astro's scoped
     data-astro-cid attribute — a bare `.tstc__dot` here compiles to
     `.tstc__dot[data-astro-cid-…]` and silently matches nothing, leaving the
     browser's default button styling. Scoping through the server-rendered
     wrapper with :global() is what actually reaches them.
     The button itself is a full 44px-tall tap target; the visible 3px bar is
     a centered ::after so the flat, minimal look doesn't shrink the hit area. */
  .tstc__dots :global(.tstc__dot) {
    appearance: none;
    flex: none; padding: 0; border: none; cursor: pointer;
    width: 24px; height: 44px;
    background: transparent;
    display: flex; align-items: center; justify-content: center;
    transition: width .3s ease-in-out;
  }
  .tstc__dots :global(.tstc__dot)::after {
    content: ''; display: block; width: 100%; height: 3px; border-radius: 2px;
    background: rgba(212, 175, 106, .28);
    transition: background-color .3s ease-in-out;
  }
  .tstc__dots :global(.tstc__dot:hover)::after { background: rgba(212, 175, 106, .5); }
  .tstc__dots :global(.tstc__dot.active) { width: 44px; }
  .tstc__dots :global(.tstc__dot.active)::after { background: var(--gold-dark); }
  .tstc__dots :global(.tstc__dot.active:hover)::after { background: var(--gold-dark); }

  .quote { margin: 0; text-align: center; display: flex; flex-direction: column; gap: 16px; align-items: center; }
  .quote__mark {
    font-family: var(--serif); font-size: 64px; line-height: .5; margin-top: 20px;
    background: linear-gradient(100deg, var(--gold-dark), var(--gold));
    -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;
  }
  .quote__text { margin: 0; font-family: var(--serif); font-size: 20px; line-height: 1.6; font-style: italic; font-weight: 400; max-width: 52ch; }
  .quote__rule { width: 40px; height: 1px; background: var(--grad-gold); }
  .quote__attribution { display: flex; flex-direction: column; align-items: center; gap: 5px; }
  .quote__person { font-family: var(--serif); font-size: 16px; font-weight: 600; color: var(--ink); }
  .quote__role { font-size: 11.5px; letter-spacing: .26em; text-transform: uppercase; color: var(--muted); }

  /* FAQ accordion (mirrors the quote-form step accordion) */
  .faq { background: var(--cream); padding: 48px 28px; }
  .faq__title { margin: 0 auto 34px; }

  .faq__list { max-width: 800px; margin: 0 auto; }
  .faq__item { border-top: 1px solid var(--line-2); }
  .faq__item:last-child { border-bottom: 1px solid var(--line-2); }
  .faq__head {
    width: 100%; display: flex; align-items: center; gap: 20px;
    padding: 24px 4px; background: transparent; border: 0; cursor: pointer;
    text-align: left; font-family: var(--serif); color: var(--ink);
  }
  .faq__q { flex: 1; font-size: 20px; font-weight: 600; line-height: 1.35; }
  .faq__chev {
    flex: none; width: 10px; height: 10px;
    border-right: 1.5px solid var(--gold-deep); border-bottom: 1.5px solid var(--gold-deep);
    transform: translateY(-2px) rotate(45deg); transition: transform .3s ease;
  }
  .faq__item.is-open .faq__chev { transform: translateY(2px) rotate(-135deg); }
  .faq__panel { display: grid; grid-template-rows: 0fr; transition: grid-template-rows .35s ease; }
  .faq__item.is-open .faq__panel { grid-template-rows: 1fr; }
  .faq__body { overflow: hidden; min-height: 0; }
  .faq__a { margin: 0; padding: 0 4px 26px; font-weight: 300; font-size: 15px; line-height: 1.8; color: var(--muted); max-width: 66ch; }

  /* Guides preview */
  .guidesp { background: var(--paper); padding: 40px 28px; }
  .guidesp__title { margin-bottom: 14px; }
  .guidesp__lead {
    text-align: center; font-weight: 300; font-size: 15.5px; color: var(--muted);
    margin: 0 auto 52px; max-width: 52ch;
  }
  .guidesp__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; }
  .guidesp__cta { text-align: center; margin-top: 48px; }

  @media (max-width: 900px) {
    .guidesp__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 640px) {
    .guidesp__grid { grid-template-columns: 1fr; }
    .tstc__viewport {
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scrollbar-width: none;
      -webkit-overflow-scrolling: touch;
    }
    .tstc__viewport::-webkit-scrollbar { display: none; }
    .tstc__track { transform: none !important; }
    .tstc__slide {
      padding-inline: 0;
      scroll-snap-align: start;
      scroll-snap-stop: always;
    }
  }

  @media (max-width: 560px) {
    .tstc { gap: 2px; }
    .tstc__arrow svg { width: 20px; height: 20px; }
    .faq__q { font-size: 17px; }
    .faq__head { gap: 14px; padding: 20px 2px; }
  }
  @media (prefers-reduced-motion: reduce) {
    .fleetp__img, .fleet-card, .tstc__track, .faq__panel, .faq__chev { transition: none; }
  }
</style>

<script>
  const certificateOpen = document.querySelector<HTMLButtonElement>('[data-certificate-open]');
  const certificateDialog = document.querySelector<HTMLDialogElement>('[data-certificate-dialog]');
  const certificateClose = certificateDialog?.querySelector<HTMLButtonElement>('[data-certificate-close]');

  certificateOpen?.addEventListener('click', () => {
    certificateDialog?.showModal();
  });

  certificateClose?.addEventListener('click', () => {
    certificateDialog?.close();
  });

  certificateDialog?.addEventListener('click', (event) => {
    if (event.target === certificateDialog) certificateDialog.close();
  });
</script>

<script>
  // Multi-step accordion wizard + explicit not-connected status.
  const form = document.querySelector<HTMLFormElement>('[data-quote-form]');
  const confirm = document.querySelector<HTMLElement>('[data-quote-confirm]');
  const reset = document.querySelector<HTMLButtonElement>('[data-quote-reset]');

  if (form) {
    const steps = Array.from(form.querySelectorAll<HTMLElement>('.step'));
    const stepByNum = (n: string) => steps.find((s) => s.dataset.step === n);

    // Sync a step's open state across class, aria, and inert (keeps hidden
    // fields out of the tab order while preserving their values).
    const setOpen = (step: HTMLElement, open: boolean) => {
      step.classList.toggle('is-open', open);
      step.querySelector('.step__head')?.setAttribute('aria-expanded', String(open));
      const body = step.querySelector<HTMLElement>('.step__body');
      if (body) body.inert = !open;
    };

    const openStep = (n: string, focus = true) => {
      steps.forEach((s) => setOpen(s, s.dataset.step === n));
      if (focus) {
        const first = stepByNum(n)?.querySelector<HTMLElement>('.step__body .field__control');
        first?.focus({ preventScroll: true });
      }
    };

    const toggleStep = (n: string) => {
      const step = stepByNum(n);
      if (!step) return;
      if (step.classList.contains('is-open')) steps.forEach((s) => setOpen(s, false));
      else openStep(n, false);
    };

    // Wire headers (accordion), Next, and Back.
    form.querySelectorAll<HTMLElement>('[data-step-toggle]').forEach((btn) =>
      btn.addEventListener('click', () => toggleStep(btn.dataset.stepToggle!)),
    );
    form.querySelectorAll<HTMLElement>('[data-step-next]').forEach((btn) =>
      btn.addEventListener('click', () => {
        btn.closest<HTMLElement>('.step')?.classList.add('is-done');
        openStep(btn.dataset.stepNext!);
      }),
    );
    form.querySelectorAll<HTMLElement>('[data-step-back]').forEach((btn) =>
      btn.addEventListener('click', () => openStep(btn.dataset.stepBack!)),
    );

    // Initialize inert/aria from the markup's default (Step 1 open).
    steps.forEach((s) => setOpen(s, s.classList.contains('is-open')));

    // Pre-select a vehicle when arriving from a fleet detail page (?vehicle=…).
    const wantVehicle = new URLSearchParams(location.search).get('vehicle');
    if (wantVehicle) {
      const sel = form.querySelector<HTMLSelectElement>('select[name="vehicle"]');
      const match = sel && Array.from(sel.options).find((o) => o.text === wantVehicle);
      if (sel && match) sel.value = match.value;
    }

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      if (!form.reportValidity()) return;
      form.hidden = true;
      if (confirm) {
        confirm.hidden = false;
        confirm.focus();
      }
    });
    reset?.addEventListener('click', () => {
      if (confirm) confirm.hidden = true;
      form.hidden = false;
      form.reset();
      steps.forEach((s) => s.classList.remove('is-done'));
      openStep('1', false);
      form.querySelector<HTMLElement>('.field__control')?.focus();
    });
  }
</script>

<script>
  // Testimonials carousel — auto-advance, arrows, dots, pause on hover.
  const carousel = document.querySelector<HTMLElement>('[data-carousel]');
  if (carousel) {
    const track = carousel.querySelector<HTMLElement>('[data-carousel-track]');
    const viewport = carousel.querySelector<HTMLElement>('.tstc__viewport');
    const slides = track ? (Array.from(track.children) as HTMLElement[]) : [];
    const dotsWrap = carousel.parentElement?.querySelector<HTMLElement>('[data-carousel-dots]');
    const prev = carousel.querySelector<HTMLButtonElement>('[data-carousel-prev]');
    const next = carousel.querySelector<HTMLButtonElement>('[data-carousel-next]');
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const mobileCarousel = window.matchMedia('(max-width: 640px)');

    if (track && viewport && slides.length) {
      const count = slides.length;
      let index = 0;
      let timer = 0;

      const go = (i: number) => {
        index = (i + count) % count;
        if (mobileCarousel.matches) {
          track.style.transform = '';
          viewport.scrollTo({ left: index * viewport.clientWidth, behavior: reduce ? 'auto' : 'smooth' });
        } else {
          viewport.scrollLeft = 0;
          track.style.transform = `translateX(-${index * 100}%)`;
        }
        dots.forEach((d, di) => d.classList.toggle('active', di === index));
      };
      const start = () => {
        window.clearInterval(timer);
        if (!reduce) timer = window.setInterval(() => go(index + 1), 7000);
      };

      // Build pagination dots.
      const dots: HTMLButtonElement[] = slides.map((_, i) => {
        const dot = document.createElement('button');
        dot.type = 'button';
        dot.className = 'tstc__dot';
        dot.setAttribute('aria-label', `Go to testimonial ${i + 1}`);
        dot.addEventListener('click', () => { go(i); start(); });
        dotsWrap?.appendChild(dot);
        return dot;
      });

      prev?.addEventListener('click', () => { go(index - 1); start(); });
      next?.addEventListener('click', () => { go(index + 1); start(); });
      let scrollFrame = 0;
      viewport.addEventListener('scroll', () => {
        if (!mobileCarousel.matches) return;
        window.cancelAnimationFrame(scrollFrame);
        scrollFrame = window.requestAnimationFrame(() => {
          const nextIndex = Math.round(viewport.scrollLeft / viewport.clientWidth);
          if (nextIndex !== index && nextIndex >= 0 && nextIndex < count) {
            index = nextIndex;
            dots.forEach((d, di) => d.classList.toggle('active', di === index));
          }
        });
      }, { passive: true });
      mobileCarousel.addEventListener('change', () => go(index));
      carousel.addEventListener('mouseenter', () => window.clearInterval(timer));
      carousel.addEventListener('mouseleave', start);

      go(0);
      start();
    }
  }

  // FAQ accordion — single item open at a time (matches the quote-form pattern).
  const faq = document.querySelector<HTMLElement>('[data-faq]');
  if (faq) {
    const items = Array.from(faq.querySelectorAll<HTMLElement>('.faq__item'));
    const setFaqOpen = (item: HTMLElement, open: boolean) => {
      item.classList.toggle('is-open', open);
      item.querySelector('[data-faq-toggle]')?.setAttribute('aria-expanded', String(open));
      const body = item.querySelector<HTMLElement>('.faq__body');
      if (body) body.inert = !open;
    };
    items.forEach((item) => {
      item.querySelector<HTMLButtonElement>('[data-faq-toggle]')?.addEventListener('click', () => {
        const wasOpen = item.classList.contains('is-open');
        items.forEach((it) => setFaqOpen(it, false));
        if (!wasOpen) setFaqOpen(item, true);
      });
      setFaqOpen(item, false); // init: closed + inert
    });
  }
</script>
