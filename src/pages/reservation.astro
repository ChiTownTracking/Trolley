---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import { site, eventTypes, vehicleOptions, hoursOptions, resNotes, hasPhone } from '../data/site';
---
<BaseLayout
  title="Reserve Your Ride — ChiTown Trolley"
  description="Request a reservation for your Chicago wedding or event. Tell us the where and when — we'll confirm availability and hold your date. No payment required to request."
>
  <PageHero eyebrow="Reservation" pb={48}>
    Reserve <em class="grad">your ride</em>
    <p slot="lead">Tell us the where and when — we'll confirm availability and hold your date. No payment required to request.</p>
  </PageHero>

  <section class="res wrap wrap-1060">
    <div class="res__formcol">
      <form class="rform" data-res-form>
        <label class="field">
          <span class="field__label">Name</span>
          <input required name="name" type="text" placeholder="Your full name" class="field__control" />
        </label>
        <label class="field">
          <span class="field__label">Phone</span>
          <input required name="phone" type="tel" placeholder="(312) 555-0000" class="field__control" />
        </label>
        <label class="field field--full">
          <span class="field__label">Email</span>
          <input required name="email" type="email" placeholder="you@example.com" class="field__control" />
        </label>
        <label class="field">
          <span class="field__label">Event Date</span>
          <input required name="date" type="date" class="field__control" />
        </label>
        <label class="field">
          <span class="field__label">Pickup Time</span>
          <input required name="time" type="time" class="field__control" />
        </label>
        <label class="field">
          <span class="field__label">Vehicle</span>
          <select name="vehicle" class="field__control">
            {vehicleOptions.map((v) => <option>{v}</option>)}
          </select>
        </label>
        <label class="field">
          <span class="field__label">Hours</span>
          <select name="hours" class="field__control">
            {hoursOptions.map((h) => <option>{h}</option>)}
          </select>
        </label>
        <label class="field">
          <span class="field__label">Event Type</span>
          <select name="type" class="field__control">
            {eventTypes.map((t) => <option>{t}</option>)}
          </select>
        </label>
        <label class="field">
          <span class="field__label">Passengers</span>
          <input name="passengers" type="number" min="1" max="57" placeholder="Up to 57" class="field__control" />
        </label>
        <label class="field">
          <span class="field__label">Alcohol on board?</span>
          <select name="alcohol" class="field__control">
            <option>No</option>
            <option>Yes — guests are 21+</option>
          </select>
        </label>
        <label class="field">
          <span class="field__label">Pickup Address</span>
          <input name="pickup" type="text" placeholder="Street, city" class="field__control" />
        </label>
        <label class="field">
          <span class="field__label">Drop-off Address</span>
          <input name="dropoff" type="text" placeholder="Street, city" class="field__control" />
        </label>
        <label class="field field--full">
          <span class="field__label">Notes</span>
          <textarea name="notes" rows="3" placeholder="Stops along the way, decorations, anything we should know" class="field__control"></textarea>
        </label>
        <div class="rform__submit">
          <button type="submit" class="btn-gold">Request Reservation</button>
        </div>
      </form>

      <div class="confirm" data-res-confirm role="alert" aria-labelledby="reservation-form-status-title" tabindex="-1" hidden>
        <span class="confirm__mark">✳</span>
        <h2 class="confirm__title" id="reservation-form-status-title">Online request not sent</h2>
        <p class="confirm__body">No information was delivered. Online form integration is not configured yet; please contact ChiTown Trolley directly.</p>
        <button type="button" class="link-gold" data-res-reset>Return to form</button>
      </div>
    </div>

    <aside class="aside">
      <div>
        <p class="aside__eyebrow">Rather book by phone?</p>
        {hasPhone ? (
          <a href={site.contact.phoneHref} class="aside__phone">{site.contact.phoneDisplay}</a>
        ) : (
          <span class="aside__phone">{site.contact.phoneDisplay}</span>
        )}
        <a href={`mailto:${site.contact.email}`} class="aside__email">{site.contact.email}</a>
      </div>
      <div class="rule-gold"></div>
      <div class="aside__notes">
        {resNotes.map((rn) => (
          <div class="resnote">
            <span class="resnote__diamond">◆</span>
            <p class="resnote__text">{rn}</p>
          </div>
        ))}
      </div>
    </aside>
  </section>
</BaseLayout>

<style>
  .res {
    padding: 0 28px 100px;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(320px, 100%), 1fr));
    gap: 64px;
    align-items: start;
  }
  .rform { display: grid; grid-template-columns: 1fr 1fr; gap: 22px; }
  .rform__submit { grid-column: 1 / -1; margin-top: 8px; }

  .confirm__title { font-family: var(--serif); font-size: 28px; font-weight: 600; margin: 0; }
  .confirm__body { font-weight: 300; font-size: 15px; line-height: 1.8; color: var(--muted); margin: 0; max-width: 38ch; }

  .aside { display: flex; flex-direction: column; gap: 36px; }
  .aside__eyebrow { font-size: 11px; letter-spacing: .3em; text-transform: uppercase; color: var(--gold-deep); font-weight: 500; margin: 0 0 12px; }
  .aside__phone {
    font-family: var(--serif); font-size: 30px; font-weight: 600;
    color: var(--ink); text-decoration: none; display: block; transition: color .25s ease;
  }
  .aside__phone:hover { color: var(--gold-deep); }
  .aside__email { font-weight: 300; font-size: 15px; color: var(--muted); text-decoration: none; display: block; margin-top: 6px; transition: color .25s ease; }
  .aside__email:hover { color: var(--gold-deep); }
  .aside__notes { display: flex; flex-direction: column; gap: 18px; }
  .resnote { display: flex; gap: 14px; align-items: baseline; }
  .resnote__diamond { color: var(--gold-dark); font-size: 11px; flex: none; }
  .resnote__text { font-weight: 300; font-size: 14.5px; line-height: 1.75; color: var(--muted); margin: 0; }

  @media (max-width: 520px) {
    .rform { grid-template-columns: 1fr; }
  }
</style>

<script>
  const form = document.querySelector<HTMLFormElement>('[data-res-form]');
  const confirm = document.querySelector<HTMLElement>('[data-res-confirm]');
  const reset = document.querySelector<HTMLButtonElement>('[data-res-reset]');

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    if (!form.reportValidity()) return;
    form.hidden = true;
    if (confirm) {
      confirm.hidden = false;
      confirm.focus();
    }
  });
  reset?.addEventListener('click', () => {
    if (confirm) confirm.hidden = true;
    if (form) {
      form.hidden = false;
      form.reset();
      form.querySelector<HTMLElement>('.field__control')?.focus();
    }
  });
</script>
