---
import BaseLayout from '../layouts/BaseLayout.astro';
import Eyebrow from '../components/Eyebrow.astro';
import CtaBand from '../components/CtaBand.astro';
import { site } from '../data/site';
import { christmasDecor, christmasGallery } from '../data/christmas-images';
import { withBase } from '../utils/paths';
import christmasHeaderBackground from '../assets/images/christmas/gallery/christmas-header-bg.png';

// Dedicated Christmas header artwork.
const heroImage = christmasHeaderBackground;
// Preserve the approved feature grid that previously excluded gallery image 2.
const featureImages = christmasGallery.filter((_, index) => index !== 1).slice(0, 4);
// Full gallery: everything.
const gallery = christmasGallery;

// Matches the "Choose Vehicle" option so the quote form pre-selects it.
const quoteHref = withBase(`/?vehicle=${encodeURIComponent('Christmas Trolley · 24–36')}#getquote`);

// Restrained decor accents — transparent garland/wreath cutouts imported
// explicitly from the Christmas image data module.
const featureList = [
  'BYOB private trolley tours',
  'Seats 24 to 36 guests',
  'Circular perimeter seating',
  'Enclosed and heated trolley',
  'Premium Bluetooth sound system',
  'Rear balcony platform for photos',
  'Christmas lights inside and out',
  'Limited seasonal availability — book early',
];
---
<BaseLayout
  title="Christmas Trolley — Private Holiday Lights Tours in Chicago | ChiTown Trolley"
  description="Tour Chicago's holiday lights aboard a heated, twinkling white trolley. Private BYOB Christmas tours for 24–36 guests across the city and suburbs. Seasonal dates book early."
  hideCta={true}
>
  <!-- ═══ Festive hero ═══ -->
  <section class="xhero" style={`background-image: url('${heroImage.src}')`}>
    <div class="xhero__lights" aria-hidden="true"></div>
    <div class="xhero__overlay"></div>
    <div class="xhero__content">
      <p class="xhero__kicker">A ChiTown Trolley Holiday Tradition</p>
      <h1 class="xhero__title">
        Chicago's <em class="grad">Christmas Trolley</em>
      </h1>
      <p class="xhero__lead">Private holiday lights tours across Chicago &amp; the suburbs — heated, glowing, and yours for the evening.</p>
     
    </div>
  </section>

  <!-- ═══ What's included ═══ -->
  <section class="rv xfeat">
    <div class="xfeat__inner wrap wrap-1140">
      <div class="xfeat__photos">
        {featureImages.map((image, i) => (
          <img
            src={image.src}
            width={image.width}
            height={image.height}
            alt={`Christmas trolley with holiday lights — photo ${i + 1}`}
            class="xfeat__img"
            loading="lazy"
            decoding="async"
          />
        ))}
      </div>
      <div class="xfeat__list">
        <Eyebrow label="The Christmas Trolley" align="left" mb={14} />
        <h2 class="xfeat__title">Everything the season <em class="grad">calls for</em></h2>
        <ul class="xfeat__items">
          {featureList.map((f, i) => (
            <li class="xfeat__item">
              <span class="xicon" aria-hidden="true">
                {i % 3 === 0 && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"><path d="M12 2v20M4 6l16 12M20 6L4 18M12 5l-2.5-2M12 5l2.5-2M12 19l-2.5 2M12 19l2.5 2M6.2 7.6l-3.2.9M6.2 16.4l-3.2-.9M17.8 7.6l3.2.9M17.8 16.4l3.2-.9"/></svg>
                )}
                {i % 3 === 1 && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="13.5" r="7"/><path d="M10 6.5V4.8c0-.5.4-.8.9-.8h2.2c.5 0 .9.3.9.8v1.7M9 11c1 1 5 1 6 0"/></svg>
                )}
                {i % 3 === 2 && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="9" width="16" height="12" rx="1"/><path d="M4 13h16M12 9v12M12 9s-4 0-5.2-1.6C5.6 5.8 7 4 8.6 4.6 10.4 5.3 12 9 12 9Zm0 0s4 0 5.2-1.6C18.4 5.8 17 4 15.4 4.6 13.6 5.3 12 9 12 9Z"/></svg>
                )}
              </span>
              <span class:list={['xfeat__text', { 'xfeat__text--note': i === featureList.length - 1 }]}>{f}</span>
            </li>
          ))}
        </ul>
        <a href={quoteHref} class="btn-gold xfeat__cta">Get Your Quote Now</a>
      </div>
    </div>
  </section>

  <!-- ═══ Gallery (dark) ═══ -->
  <section class="rv xgal-band">
    <div class="xgal-band__garland xgal-band__garland--top" style={`--decor-img: url('${christmasDecor.garlandStrand.src}')`} aria-hidden="true"></div>
    <div class="wrap wrap-1000">
      <Eyebrow label="Aglow After Dark" mb={14} />
      <h2 class="h-section text-center xgal-band__title">The trolley, <em class="grad">dressed for December</em></h2>
      <div class="gal" data-gallery tabindex="0" aria-label="Christmas trolley photo gallery">
        <div class="gal__main">
          {gallery.map((image, i) => (
            <img
              src={image.src}
              width={image.width}
              height={image.height}
              alt={`Christmas trolley — photo ${i + 1}`}
              class:list={['gal__img', { 'is-active': i === 0 }]}
              data-gal-slide
              loading={i === 0 ? 'eager' : 'lazy'}
              decoding="async"
            />
          ))}
          <button type="button" class="gal__arrow gal__arrow--prev" data-gal-prev aria-label="Previous image">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"></polyline></svg>
          </button>
          <button type="button" class="gal__arrow gal__arrow--next" data-gal-next aria-label="Next image">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"></polyline></svg>
          </button>
        </div>
        <div class="gal__thumbs" data-gal-thumbs>
          {gallery.map((image, i) => (
            <button type="button" class:list={['gal__thumb', { 'is-active': i === 0 }]} data-gal-thumb={i} aria-label={`Show image ${i + 1}`}>
              <img src={image.src} width={image.width} height={image.height} alt="" loading="lazy" decoding="async" />
            </button>
          ))}
        </div>
      </div>
    </div>
    
  </section>

  <!-- ═══ Seasonal narrative ═══ -->
  <section class="rv xstory wrap wrap-760">
    <Eyebrow label="The Experience" mb={20} />
    <p class="xstory__body">
      As dusk settles over the neighborhoods, the trolley glows to life — strings of lights tracing
      its roofline, garlands and twinkle inside the cabin, and the heater humming against the
      December air. Your chauffeur winds past the season's best-dressed streets while your own
      playlist carries through the Bluetooth sound system, <em>cocoa in hand, everyone facing each
      other</em> on the circular benches. And when the perfect block of lights appears, the rear
      balcony is waiting for the photo your family will send with next year's cards.
    </p>
  </section>

  <!-- ═══ Festive CTA band ═══ -->
  <div class="xcta-wrap">
    <div class="xcta-wrap__garland" style={`--decor-img: url('${christmasDecor.garlandStripBottom.src}')`} aria-hidden="true"></div>
    <CtaBand
      title="The holidays won't wait — reserve your trolley"
      sub={`Seasonal dates fill fast. Call ${site.contact.phoneDisplay} or request a quote in under two minutes.`}
      ctaLabel="Get a Free Quote"
      ctaHref={quoteHref}
    />
  </div>
</BaseLayout>

<style>
  /* Text accents lean into real Christmas red/green — the same #00BF4C /
     #C8102E used on the "Christmas Trolley" nav link — layered over the
     site's black/gold. Gold is kept on the signature script headlines and
     the primary buttons so the page still reads as the same brand. */

  /* ── Hero ─────────────────────────────────────────────── */
  .xhero {
    position: relative;
    height: 285px;
    overflow: hidden;
    background-color: #0E1524;
    background-size: cover;
    background-position: center 22%;
  }
  /* A string of small red/green bulbs along the hero's top edge, blinking
     out of phase (red bright while green dims, and vice versa) — a CSS-only
     stand-in for string lights, no image asset required. */
  .xhero__lights {
    position: absolute; top: 0; left: 0; right: 0; z-index: 3;
    height: clamp(24px, 3.4vw, 34px);
    pointer-events: none;
  }
  .xhero__lights::before,
  .xhero__lights::after {
    content: ''; position: absolute; top: 7px; left: 0; right: 0; height: 12px;
    background-repeat: repeat-x;
    background-size: 64px 12px;
  }
  .xhero__lights::before {
    background-image: radial-gradient(
      circle 3px at 8px 6px,
      #ff6b6b 0%, #d21f3c 50%, rgba(210, 31, 60, .35) 68%, transparent 78%
    );
    animation: xblink-red 1.7s ease-in-out infinite;
  }
  .xhero__lights::after {
    background-image: radial-gradient(
      circle 3px at 40px 6px,
      #7be89a 0%, #1f8a4c 50%, rgba(31, 138, 76, .35) 68%, transparent 78%
    );
    animation: xblink-green 1.7s ease-in-out infinite;
  }
  @keyframes xblink-red { 0%, 40% { opacity: 1; } 50%, 90% { opacity: .3; } 100% { opacity: 1; } }
  @keyframes xblink-green { 0%, 40% { opacity: .3; } 50%, 90% { opacity: 1; } 100% { opacity: .3; } }
  .xhero__overlay {
    position: absolute; inset: 0;
    background: linear-gradient(
      90deg,
      rgba(8, 11, 20, .84) 0%,
      rgba(8, 11, 20, .6) 34%,
      rgba(8, 11, 20, .22) 62%,
      rgba(8, 11, 20, .05) 85%
    );
  }
  .xhero__content {
    position: relative; z-index: 2; height: 100%;
    max-width: 1400px; margin: 0 auto;
    display: flex; flex-direction: column; align-items: flex-start; justify-content: center;
    gap: 22px; padding: clamp(24px, 4vw, 40px) clamp(24px, 6vw, 96px) 0;
    animation: fadeInUp 1.1s cubic-bezier(.22, .6, .2, 1) both;
  }
  .xhero__kicker {
    font-size: 11px; letter-spacing: .34em; text-transform: uppercase;
    color: var(--gold-light); margin: 0;
  }
  .xhero__title {
    font-family: var(--serif); font-weight: 500; color: #fff;
    font-size: clamp(36px, 5.4vw, 70px); line-height: 1.1; margin: 0;
    text-shadow: 0 2px 26px rgba(0, 0, 0, .45);
  }
  .xhero__lead {
    font-weight: 300; font-size: 16.5px; letter-spacing: .02em;
    color: rgba(253, 252, 250, .88); max-width: 46ch; line-height: 1.7; margin: 0 0 8px;
  }

  /* ── What's included ─────────────────────────────────── */
  .xfeat { position: relative; }
  .xfeat__inner {
    padding: 40px 28px 70px 28px;
    display: grid; grid-template-columns: 1.1fr 1fr; gap: clamp(36px, 5vw, 72px);
    align-items: center;
  }
  .xfeat__photos { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  .xfeat__img {
    width: 100%; height: 200px; object-fit: cover; display: block; border-radius: 8px;
  }
  .xfeat__title { font-family: var(--serif); font-size: clamp(27px, 3vw, 36px); font-weight: 600; line-height: 1.2; margin: 0 0 28px; }
  .xfeat__items { list-style: none; margin: 0 0 34px; padding: 0; display: flex; flex-direction: column; gap: 14px; }
  .xfeat__item { display: flex; align-items: center; gap: 14px; }
  /* Eyebrow above the feature list — red, to lead with the Christmas theme. */
  .xfeat :global(.eyebrow__label) { color: #C8102E; }
  .xfeat :global(.eyebrow__rule) {
    background: linear-gradient(90deg, transparent, #C8102E);
  }
  .xfeat :global(.eyebrow__rule--r) {
    background: linear-gradient(90deg, #C8102E, transparent);
    display: none;
  }
  .xicon { flex: none; width: 22px; height: 22px; color: var(--gold-dark); }
  .xicon svg { width: 100%; height: 100%; }
  /* Icons cycle gold → green → red so the seasonal palette reads as real
     accent color, not just a single exception at the end. */
  .xfeat__item:nth-child(3n+2) .xicon { color: #00BF4C; }
  .xfeat__item:nth-child(3n+3) .xicon { color: #C8102E; }
  .xfeat__text { font-weight: 300; font-size: 15px; color: var(--muted); }
  /* The scarcity note gets a Christmas-red emphasis */
  .xfeat__text--note { color: #C8102E; font-weight: 400; }
  .xfeat__item:last-child .xicon { color: #C8102E; }
  .xfeat__cta { align-self: flex-start; }

  /* ── Dark gallery band ───────────────────────────────── */
  .xgal-band {
    position: relative;
    /* Deep pine-to-black blend (was navy) — lets the garland frame and gold
       photos read as genuinely "Christmas" rather than just "dark". */
    background:
      radial-gradient(circle 1px at 18% 22%, rgba(255, 255, 255, .16) 50%, transparent 60%),
      radial-gradient(circle 1px at 64% 9%, rgba(255, 255, 255, .1) 50%, transparent 60%),
      radial-gradient(circle 1px at 41% 64%, rgba(255, 255, 255, .08) 50%, transparent 60%),
      radial-gradient(circle 1px at 87% 46%, rgba(255, 255, 255, .12) 50%, transparent 60%),
      linear-gradient(165deg, #142A20 0%, #0A1712 55%, #05100B 100%);
    padding: 60px 28px 92px;
  }
  .xgal-band :global(.eyebrow__label) { color: var(--gold-light); }
  .xgal-band__title { color: #fff; margin-bottom: 46px; }

  /* Garland strands framing the section's top and bottom edges */
  .xgal-band__garland {
    position: absolute; left: 0; right: 0;
    height: clamp(56px, 8vw, 96px);
    background-image: var(--decor-img);
    background-repeat: repeat-x; background-size: auto 100%;
    pointer-events: none;
  }
  .xgal-band__garland--top {
    top: -32px; background-position: top center;
    -webkit-mask-image: linear-gradient(to bottom, #000 55%, transparent 100%);
    mask-image: linear-gradient(to bottom, #000 55%, transparent 100%);
  }

  .gal { outline: none; }
  .gal__main {
    position: relative; height: clamp(280px, 44vw, 520px);
    border-radius: 10px; overflow: hidden; background: #16281F;
  }
  .gal__img {
    position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover;
    opacity: 0; transition: opacity .5s ease;
  }
  .gal__img.is-active { opacity: 1; }
  .gal__arrow {
    position: absolute; top: 50%; transform: translateY(-50%); z-index: 2;
    width: 44px; height: 44px; border-radius: 50%; border: 0; cursor: pointer;
    background: rgba(253, 252, 250, .85); color: var(--ink);
    display: grid; place-items: center; box-shadow: 0 2px 12px rgba(0, 0, 0, .3);
    transition: background .2s ease, color .2s ease;
  }
  .gal__arrow:hover { background: #fff; color: var(--gold-deep); }
  .gal__arrow svg { width: 20px; height: 20px; }
  .gal__arrow--prev { left: 14px; }
  .gal__arrow--next { right: 14px; }
  .gal__thumbs { display: flex; gap: 12px; margin-top: 14px; overflow-x: auto; padding-bottom: 4px; scrollbar-width: thin; }
  .gal__thumb {
    flex: 0 0 auto; width: 96px; height: 66px; padding: 0; cursor: pointer;
    border: 2px solid transparent; border-radius: 6px; overflow: hidden; background: none;
    opacity: .55; transition: opacity .25s ease, border-color .25s ease;
  }
  .gal__thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .gal__thumb:hover { opacity: 1; }
  .gal__thumb.is-active { border-color: var(--gold); opacity: 1; }

  /* ── Narrative ───────────────────────────────────────── */
  .xstory { padding: 50px 28px 72px; text-align: center; }
  .xstory :global(.eyebrow__label) { color: #C8102E; }
  .xstory__body {
    font-family: var(--serif); font-size: 23px; line-height: 1.65;
    font-weight: 400; color: var(--ink); margin: 0; text-align: left;
  }
  .xstory__body em { color: #00BF4C; }

  /* ── Festive CTA garland (bookends the hero treatment) ── */
  .xcta-wrap { position: relative; }
  .xcta-wrap__garland {
    position: absolute; top: -6px; left: 0; right: 0; z-index: 2;
    height: clamp(48px, 7vw, 84px);
    background-image: var(--decor-img);
    background-repeat: repeat-x; background-position: top center; background-size: auto 100%;
    -webkit-mask-image: linear-gradient(to bottom, #000 55%, transparent 100%);
    mask-image: linear-gradient(to bottom, #000 55%, transparent 100%);
    pointer-events: none;
  }

  /* ── Responsive ──────────────────────────────────────── */
  @media (max-width: 860px) {
    .xfeat__inner {
      display: flex;
      flex-direction: column;
      align-items: stretch;
      gap: 0;
    }
    .xfeat__list { display: contents; }
    .xfeat__list :global(.eyebrow) {
      order: 1;
      justify-content: center;
    }
    .xfeat__list :global(.eyebrow__rule--r) { display: block; }
    .xfeat__title {
      order: 2;
      text-align: center;
    }
    .xfeat__photos { order: 3; margin-bottom: 28px; }
    .xfeat__items { order: 4; }
    .xfeat__cta { order: 5; }
    .xfeat__img { height: 170px; }
  }
  @media (max-width: 640px) {
    .xhero { height: 250px; }
    .xhero__overlay {
      background: linear-gradient(90deg, rgba(8, 11, 20, .88) 0%, rgba(8, 11, 20, .68) 55%, rgba(8, 11, 20, .42) 100%);
    }
    .xhero__lights { height: clamp(20px, 5vw, 28px); }
    .xstory__body { font-size: 20px; }
  
    .xcta-wrap__garland { height: clamp(34px, 8vw, 48px); }
    /* Kept at 44px (not shrunk) — that's the tap-target minimum. */
  }
  @media (prefers-reduced-motion: reduce) {
    .xhero__lights::before, .xhero__lights::after { animation: none; opacity: .85; }
    .gal__img { transition: none; }
  }
</style>

<script>
  // Gallery: thumbnails + arrows with crossfade (same pattern as fleet detail pages).
  document.querySelectorAll<HTMLElement>('[data-gallery]').forEach((gal) => {
    const slides = Array.from(gal.querySelectorAll<HTMLElement>('[data-gal-slide]'));
    const thumbs = Array.from(gal.querySelectorAll<HTMLElement>('[data-gal-thumb]'));
    if (slides.length < 2) return;
    let idx = 0;

    const show = (i: number) => {
      idx = (i + slides.length) % slides.length;
      slides.forEach((s, si) => s.classList.toggle('is-active', si === idx));
      thumbs.forEach((t, ti) => t.classList.toggle('is-active', ti === idx));
      thumbs[idx]?.scrollIntoView({ inline: 'nearest', block: 'nearest', behavior: 'smooth' });
    };

    thumbs.forEach((t, i) => t.addEventListener('click', () => show(i)));
    gal.querySelector('[data-gal-prev]')?.addEventListener('click', () => show(idx - 1));
    gal.querySelector('[data-gal-next]')?.addEventListener('click', () => show(idx + 1));
    gal.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowLeft') show(idx - 1);
      else if (e.key === 'ArrowRight') show(idx + 1);
    });
  });
</script>
